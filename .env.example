# GER2 CMMS — Environment Variables Template
# Copy to .env and fill in real values before running.

# Database
DATABASE_URL=postgresql+asyncpg://ger2:CHANGE_ME@localhost:5432/ger2_cmms

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Security
SECRET_KEY=GENERATE_A_32_BYTE_RANDOM_STRING_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# DICOM
DICOM_AE_TITLE=GER2_CMMS
DICOM_WADO_RS_URL=http://orthanc:8042/wado
DICOM_STOW_RS_URL=http://orthanc:8042/instances

# OPC-UA
OPCUA_SERVER_URL=opc.tcp://opcua-server:4840

# FHIR
FHIR_SERVER_URL=http://fhir:8080/fhir

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MODEL_RUL_PATH=/models/rul_ensemble.onnx
